+                let device = B::Device::default();
                 let record = burn::record::load(path, &FullPrecisionSettings::default())
                     .map_err(|e| OptimizerError::LoadError(e.to_string()))?;
                 let model = Model::from_record(record, &device)
                     .map_err(|e| OptimizerError::LoadError(e.to_string()))?;

